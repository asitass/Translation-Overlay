{
  "compilerOptions": {
    "target": "ES2020",
    "module": "none",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": false,
    "sourceMap": true,
    "outDir": "./dist/renderer",
    "rootDir": "./src/renderer",
    "types": []
  },
  "include": ["src/renderer/**/*.ts"],
  "exclude": ["node_modules", "dist", "tests"]
}
